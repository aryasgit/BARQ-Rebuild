<?xml version="1.0" ?>
<robot name="barq" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="dark_grey">  <color rgba="0.20 0.20 0.20 1.0"/> </material>
  <material name="light_grey"> <color rgba="0.65 0.65 0.65 1.0"/> </material>

  <!-- BASE LINK -->
  <link name="base_link">
    <visual>
      <origin rpy="0 0 -1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/base_link.dae" scale="1 1 1"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.258 0.117 0.085"/></geometry>
    </collision>
    <!-- Measured 2026-06-11 (Aryaman): incl. electronics/fasteners. Inertia: solid box
         0.258 x 0.117 x 0.085 at the measured mass. -->
    <inertial>
      <mass value="1.42"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="2.47e-3" ixy="0" ixz="0" iyy="8.73e-3" iyz="0" izz="9.50e-3"/>
    </inertial>
  </link>

  <!-- ═══════════════ FL LEG ═══════════════ -->
  <joint name="FL_hip_joint" type="revolute">
    <parent link="base_link"/>    <child link="FL_coxa_link"/>
    <origin rpy="0 0 0" xyz="0.108484 0.0171913 0.00022012"/>
    <axis xyz="1 0 0"/>
    <limit effort="2.94" lower="-0.785" upper="0.785" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="FL_coxa_link">
    <visual>
      <origin rpy="3.14159265358979 0 -1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/coxa.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.0733"/>
      <origin rpy="0 0 0" xyz="0.00872 0.0215346 0"/>
      <inertia ixx="3.2e-5" ixy="0" ixz="0" iyy="2.0e-5" iyz="0" izz="3.2e-5"/>
    </inertial>
  </link>

  <joint name="FL_knee_joint" type="revolute">
    <parent link="FL_coxa_link"/>    <child link="FL_femur_link"/>
    <origin rpy="0 0 0" xyz="0.01744 0.0430692 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="2.94" lower="-1.57" upper="1.57" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="FL_femur_link">
    <visual>
      <origin rpy="0 0 -1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/mid.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.1536"/>
      <origin rpy="0 0 0" xyz="0.009472 0.01769995 -0.04999995"/>
      <inertia ixx="1.7e-4" ixy="0" ixz="0" iyy="1.6e-4" iyz="0" izz="5.3e-5"/>
    </inertial>
  </link>

  <joint name="FL_ankle_joint" type="revolute">
    <parent link="FL_femur_link"/>    <child link="FL_tibia_link"/>
    <origin rpy="0 0 0" xyz="0.018944 0.03239997 -0.0999999"/>
    <axis xyz="0 1 0"/>
    <limit effort="2.94" lower="-2.2" upper="1.57" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="FL_tibia_link">
    <visual>
      <origin rpy="0 0 -1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/foot.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Contact sphere at the kinematic foot point (mesh collisions are unstable/slow in sim) -->
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.1"/>
      <geometry><sphere radius="0.012"/></geometry>
    </collision>
    <inertial>
      <mass value="0.030"/>
      <origin rpy="0 0 0" xyz="0 0 -0.04999995"/>
      <inertia ixx="3.3e-5" ixy="0" ixz="0" iyy="3.1e-5" iyz="0" izz="3.3e-6"/>
    </inertial>
  </link>

  <!-- ═══════════════ RL LEG ═══════════════ -->
  <joint name="RL_hip_joint" type="revolute">
    <parent link="base_link"/>    <child link="RL_coxa_link"/>
    <origin rpy="0 0 0" xyz="-0.108371 0.0167905 0.00022176"/>
    <axis xyz="1 0 0"/>
    <limit effort="2.94" lower="-0.785" upper="0.785" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="RL_coxa_link">
    <visual>
      <origin rpy="0 0 -1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/coxa.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.0733"/>
      <origin rpy="0 0 0" xyz="-0.00872 0.0215346 0"/>
      <inertia ixx="3.2e-5" ixy="0" ixz="0" iyy="2.0e-5" iyz="0" izz="3.2e-5"/>
    </inertial>
  </link>

  <joint name="RL_knee_joint" type="revolute">
    <parent link="RL_coxa_link"/>    <child link="RL_femur_link"/>
    <origin rpy="0 0 0" xyz="-0.01744 0.0430692 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="2.94" lower="-1.57" upper="1.57" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="RL_femur_link">
    <visual>
      <origin rpy="0 0 -1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/mid.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.1536"/>
      <origin rpy="0 0 0" xyz="0.009472 0.01769995 -0.04999995"/>
      <inertia ixx="1.7e-4" ixy="0" ixz="0" iyy="1.6e-4" iyz="0" izz="5.3e-5"/>
    </inertial>
  </link>

  <joint name="RL_ankle_joint" type="revolute">
    <parent link="RL_femur_link"/>    <child link="RL_tibia_link"/>
    <origin rpy="0 0 0" xyz="0.018944 0.03239997 -0.0999999"/>
    <axis xyz="0 1 0"/>
    <limit effort="2.94" lower="-2.2" upper="1.57" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="RL_tibia_link">
    <visual>
      <origin rpy="0 0 -1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/foot.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Contact sphere at the kinematic foot point (mesh collisions are unstable/slow in sim) -->
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.1"/>
      <geometry><sphere radius="0.012"/></geometry>
    </collision>
    <inertial>
      <mass value="0.030"/>
      <origin rpy="0 0 0" xyz="0 0 -0.04999995"/>
      <inertia ixx="3.3e-5" ixy="0" ixz="0" iyy="3.1e-5" iyz="0" izz="3.3e-6"/>
    </inertial>
  </link>

  <!-- ═══════════════ FR LEG ═══════════════ -->
  <joint name="FR_hip_joint" type="revolute">
    <parent link="base_link"/>    <child link="FR_coxa_link"/>
    <origin rpy="0 0 0" xyz="0.108484 -0.0148092 0.00022176"/>
    <axis xyz="1 0 0"/>
    <limit effort="2.94" lower="-0.785" upper="0.785" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="FR_coxa_link">
    <visual>
      <origin rpy="0 0 1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/coxa.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.0733"/>
      <origin rpy="0 0 0" xyz="0.00872 -0.0215346 0"/>
      <inertia ixx="3.2e-5" ixy="0" ixz="0" iyy="2.0e-5" iyz="0" izz="3.2e-5"/>
    </inertial>
  </link>

  <joint name="FR_knee_joint" type="revolute">
    <parent link="FR_coxa_link"/>    <child link="FR_femur_link"/>
    <origin rpy="0 0 0" xyz="0.01744 -0.0430692 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="2.94" lower="-1.57" upper="1.57" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="FR_femur_link">
    <visual>
      <origin rpy="0 0 -1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/mid_rev.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.1536"/>
      <origin rpy="0 0 0" xyz="0.00947205 -0.01769995 -0.04999995"/>
      <inertia ixx="1.7e-4" ixy="0" ixz="0" iyy="1.6e-4" iyz="0" izz="5.3e-5"/>
    </inertial>
  </link>

  <joint name="FR_ankle_joint" type="revolute">
    <parent link="FR_femur_link"/>    <child link="FR_tibia_link"/>
    <origin rpy="0 0 0" xyz="0.0189441 -0.03239997 -0.0999999"/>
    <axis xyz="0 1 0"/>
    <limit effort="2.94" lower="-2.2" upper="1.57" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="FR_tibia_link">
    <visual>
      <origin rpy="0 0 -1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/foot_rev.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Contact sphere at the kinematic foot point (mesh collisions are unstable/slow in sim) -->
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.1"/>
      <geometry><sphere radius="0.012"/></geometry>
    </collision>
    <inertial>
      <mass value="0.030"/>
      <origin rpy="0 0 0" xyz="0 0 -0.04999995"/>
      <inertia ixx="3.3e-5" ixy="0" ixz="0" iyy="3.1e-5" iyz="0" izz="3.3e-6"/>
    </inertial>
  </link>

  <!-- ═══════════════ RR LEG ═══════════════ -->
  <joint name="RR_hip_joint" type="revolute">
    <parent link="base_link"/>    <child link="RR_coxa_link"/>
    <origin rpy="0 0 0" xyz="-0.108371 -0.01521 0.00022012"/>
    <axis xyz="1 0 0"/>
    <limit effort="2.94" lower="-0.785" upper="0.785" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="RR_coxa_link">
    <visual>
      <origin rpy="3.14159265358979 0 1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/coxa.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.0733"/>
      <origin rpy="0 0 0" xyz="-0.00872 -0.0215346 0"/>
      <inertia ixx="3.2e-5" ixy="0" ixz="0" iyy="2.0e-5" iyz="0" izz="3.2e-5"/>
    </inertial>
  </link>

  <joint name="RR_knee_joint" type="revolute">
    <parent link="RR_coxa_link"/>    <child link="RR_femur_link"/>
    <origin rpy="0 0 0" xyz="-0.01744 -0.0430692 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="2.94" lower="-1.57" upper="1.57" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="RR_femur_link">
    <visual>
      <origin rpy="0 0 -1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/mid_rev.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.1536"/>
      <origin rpy="0 0 0" xyz="0.00947205 -0.01769995 -0.04999995"/>
      <inertia ixx="1.7e-4" ixy="0" ixz="0" iyy="1.6e-4" iyz="0" izz="5.3e-5"/>
    </inertial>
  </link>

  <joint name="RR_ankle_joint" type="revolute">
    <parent link="RR_femur_link"/>    <child link="RR_tibia_link"/>
    <origin rpy="0 0 0" xyz="0.0189441 -0.03239997 -0.0999999"/>
    <axis xyz="0 1 0"/>
    <limit effort="2.94" lower="-2.2" upper="1.57" velocity="5.24"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>
  <link name="RR_tibia_link">
    <visual>
      <origin rpy="0 0 -1.5708" xyz="0 0 0"/>
      <geometry><mesh filename="package://barq_description/meshes/foot_rev.dae" scale="1 1 1"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Contact sphere at the kinematic foot point (mesh collisions are unstable/slow in sim) -->
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.1"/>
      <geometry><sphere radius="0.012"/></geometry>
    </collision>
    <inertial>
      <mass value="0.030"/>
      <origin rpy="0 0 0" xyz="0 0 -0.04999995"/>
      <inertia ixx="3.3e-5" ixy="0" ixz="0" iyy="3.1e-5" iyz="0" izz="3.3e-6"/>
    </inertial>
  </link>

  <!-- ═══════════════ ros2_control (Stage 2B) ═══════════════ -->
  <!-- mode: mock (now) | gazebo (2E) | real (Stage 4). Only the <hardware> plugin changes. -->
  <xacro:arg name="mode" default="mock"/>

  <!-- init = startup joint position (the exact-model standing stance, stand_height 0.13):
       prevents the spawn collapse + first-command snap found in the 2E review. -->
  <xacro:macro name="barq_joint_if" params="name lower upper init">
    <joint name="${name}">
      <command_interface name="position">
        <param name="min">${lower}</param>
        <param name="max">${upper}</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">${init}</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </xacro:macro>

  <ros2_control name="barq_system" type="system">
    <hardware>
      <xacro:if value="${'$(arg mode)' == 'mock'}">
        <plugin>mock_components/GenericSystem</plugin>
      </xacro:if>
      <xacro:if value="${'$(arg mode)' == 'gazebo'}">
        <plugin>ign_ros2_control/IgnitionSystem</plugin>
      </xacro:if>
      <!-- mode=real (Stage 4) plugin slots in here -->
    </hardware>

    <xacro:barq_joint_if name="FL_hip_joint"   lower="-0.785" upper="0.785" init="0.0"/>
    <xacro:barq_joint_if name="FL_knee_joint"  lower="-1.57"  upper="1.57" init="1.047531"/>
    <xacro:barq_joint_if name="FL_ankle_joint" lower="-2.2"   upper="1.57" init="-1.928768"/>
    <xacro:barq_joint_if name="FR_hip_joint"   lower="-0.785" upper="0.785" init="0.0"/>
    <xacro:barq_joint_if name="FR_knee_joint"  lower="-1.57"  upper="1.57" init="1.047531"/>
    <xacro:barq_joint_if name="FR_ankle_joint" lower="-2.2"   upper="1.57" init="-1.928768"/>
    <xacro:barq_joint_if name="RL_hip_joint"   lower="-0.785" upper="0.785" init="0.0"/>
    <!-- Rear inits match the rear_raise=0.02 stance trim (depth 0.15, D-016) -->
    <xacro:barq_joint_if name="RL_knee_joint"  lower="-1.57"  upper="1.57" init="0.911998"/>
    <xacro:barq_joint_if name="RL_ankle_joint" lower="-2.2"   upper="1.57" init="-1.652637"/>
    <xacro:barq_joint_if name="RR_hip_joint"   lower="-0.785" upper="0.785" init="0.0"/>
    <xacro:barq_joint_if name="RR_knee_joint"  lower="-1.57"  upper="1.57" init="0.911998"/>
    <xacro:barq_joint_if name="RR_ankle_joint" lower="-2.2"   upper="1.57" init="-1.652637"/>
  </ros2_control>

  <!-- ═══════════════ Gazebo (Stage 2E, mode:=gazebo) ═══════════════ -->
  <xacro:if value="${'$(arg mode)' == 'gazebo'}">
    <gazebo>
      <plugin filename="ign_ros2_control-system" name="ign_ros2_control::IgnitionROS2ControlPlugin">
        <parameters>$(find barq_bringup)/config/ros2_controllers.yaml</parameters>
      </plugin>
    </gazebo>
    <gazebo reference="FL_tibia_link"><mu1>0.9</mu1><mu2>0.9</mu2></gazebo>
    <gazebo reference="FR_tibia_link"><mu1>0.9</mu1><mu2>0.9</mu2></gazebo>
    <gazebo reference="RL_tibia_link"><mu1>0.9</mu1><mu2>0.9</mu2></gazebo>
    <gazebo reference="RR_tibia_link"><mu1>0.9</mu1><mu2>0.9</mu2></gazebo>
  </xacro:if>

</robot>
